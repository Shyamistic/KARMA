{
  "name": "karma-wdk",
  "version": "3.0.0",
  "description": "Autonomous USDT tipping agent for Rumble creators and GitHub contributors",
  "main": "dist/index.js",
  "scripts": {
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "npx prisma generate && tsc",
    "build:frontend": "cd frontend && npm install && npm run build",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn src/index.ts",
    "setup-skill": "npx skills add tetherto/wdk-agent-skills"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "latest",
    "@google/generative-ai": "^0.24.1",
    "@octokit/rest": "^21.0.0",
    "@octokit/webhooks": "^13.0.0",
    "@prisma/client": "^5.22.0",
    "@tetherto/wdk": "latest",
    "@tetherto/wdk-wallet-evm": "latest",
    "@tetherto/wdk-wallet-evm-erc-4337": "latest",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/jsonwebtoken": "^9.0.10",
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "cheerio": "^1.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "ethers": "^6.0.0",
    "express": "^4.18.0",
    "groq-sdk": "^1.1.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.577.0",
    "node-cron": "^3.0.0",
    "react-router-dom": "^7.13.1",
    "socket.io": "^4.8.3",
    "sqlite": "^5.1.1",
    "sqlite3": "^6.0.1",
    "uuid": "^9.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "@types/node-cron": "^3.0.0",
    "@types/uuid": "^9.0.0",
    "prisma": "^5.22.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.0"
  }
}
