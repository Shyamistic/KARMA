generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./karma.db"
}

model GithubTip {
  id              String   @id @default(cuid())
  prNumber        Int?     @map("pr_number")
  prTitle         String?  @map("pr_title")
  prUrl           String?  @unique @map("pr_url")
  repoName        String?  @map("repo_name")
  contributor     String?
  amountUsdt      Float    @default(0) @map("amount_usdt")
  totalScore      Int      @default(0) @map("total_score")
  reasoning       String?
  tipped          Boolean  @default(false)
  txHash          String?  @map("tx_hash")
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("tips")
}

model Claim {
  id              String   @id @default(cuid())
  claimToken      String   @unique @map("claim_token")
  contributor     String
  amountUsdt      Float    @map("amount_usdt")
  prUrl           String?  @map("pr_url")
  prTitle         String?  @map("pr_title")
  repoName        String?  @map("repo_name")
  tier            String?
  reasoning       String?
  totalScore      Int      @default(0) @map("total_score")
  createdAt       DateTime @default(now()) @map("created_at")
  expiresAt       DateTime @map("expires_at")
  claimed         Boolean  @default(false)
  claimedBy       String?  @map("claimed_by")
  txHash          String?  @map("tx_hash")
  claimedAt       DateTime? @map("claimed_at")
  platform        String   @default("github")

  @@map("claims")
}

model RumbleCreator {
  username      String   @id
  walletAddress String?  @map("wallet_address")
  active        Boolean  @default(true)
  addedAt       DateTime @default(now()) @map("added_at")
  notes         String?
  
  metrics       RumbleMetric[]
  tips          RumbleTip[]
  milestones    RumbleMilestone[]

  @@map("rumble_creators")
}

model RumbleMetric {
  id                Int      @id @default(autoincrement())
  username          String
  subscribers       Int      @default(0)
  latestViews       Int      @default(0) @map("latest_views")
  viewVelocity      Int      @default(0) @map("view_velocity")
  isLive            Boolean  @default(false) @map("is_live")
  totalVideos       Int      @default(0) @map("total_videos")
  engagementRate    Float    @default(0) @map("engagement_rate")
  consistencyScore  Int      @default(0) @map("consistency_score")
  latestVideoTitle  String?  @map("latest_video_title")
  latestVideoUrl    String?  @map("latest_video_url")
  checkedAt         DateTime @default(now()) @map("checked_at")

  creator           RumbleCreator @relation(fields: [username], references: [username])

  @@map("rumble_metrics")
}

model RumbleTip {
  id              Int      @id @default(autoincrement())
  username        String
  displayName     String?  @map("display_name")
  videoTitle      String?  @map("video_title")
  videoUrl        String?  @map("video_url")
  walletAddress   String?  @map("wallet_address")
  amountUsdt      Float    @default(0) @map("amount_usdt")
  tier            String?
  totalScore      Int      @default(0) @map("total_score")
  reasoning       String?
  recipientsJson  String?  @map("recipients_json") // [NEW] For Smart Splits
  claimToken      String?  @map("claim_token")
  txHash          String?  @map("tx_hash")
  tipped          Boolean  @default(false)
  tipType         String   @default("direct") @map("tip_type")
  createdAt       DateTime @default(now()) @map("created_at")

  creator         RumbleCreator @relation(fields: [username], references: [username])

  @@map("rumble_tips")
}

model RumbleMilestone {
  username     String
  milestoneKey String   @map("milestone_key")
  rewardedAt   DateTime @default(now()) @map("rewarded_at")

  creator      RumbleCreator @relation(fields: [username], references: [username])

  @@id([username, milestoneKey])
  @@map("rumble_milestones")
}

model TippingPool {
  id          String   @id @default(cuid())
  name        String
  description String?
  totalUsdt   Float    @default(0) @map("total_usdt")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("tipping_pools")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  createdAt     DateTime  @default(now())
  pools         Pool[]
  tipRules      TipRule[]
}

model Pool {
  id            String    @id @default(cuid())
  name          String
  ownerId       String
  owner         User      @relation(fields: [ownerId], references: [id])
  balanceUsdt   Float     @default(0)
  targetCreator String?   // null = any creator
  splitConfig   Json?
  isActive      Boolean   @default(true)
  tips          Tip[]
  createdAt     DateTime  @default(now())
}

model TipRule {
  id            String    @id @default(cuid())
  ownerId       String
  owner         User      @relation(fields: [ownerId], references: [id])
  targetCreator String
  type          String
  config        Json
}

model Tip {
  id            String    @id @default(cuid())
  poolId        String?
  pool          Pool?     @relation(fields: [poolId], references: [id])
  creatorSlug   String
  creatorWallet String
  amountUsdt    Float
  txHash        String?
  network       String    @default("polygon")
  triggerType   String    // "watch_time" | "milestone" | "viral" | "pr_merge"
  triggerData   Json?
  status        String    @default("pending")
  createdAt     DateTime  @default(now())
}

model RevokedToken {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}
